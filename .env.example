# Copie este arquivo para .env e preencha os valores reais.

# ── Supabase (painel → Settings → API) ────────────────────────
NEXT_PUBLIC_SUPABASE_URL=your-supabase-project-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# ── Panda Video (painel → Configurações → Integrações → API) ──
PANDA_API_KEY=your-panda-api-key
# Pull zone do player (aparece na URL do embed: player-vz-XXXX.tv.pandavideo.com.br)
NEXT_PUBLIC_PANDA_PULL_ZONE=your-pull-zone

# ── Supabase: connection string do banco (painel → Connect → Connection string → URI)
# Usada apenas para aplicar migrations com: npx supabase db push --db-url "$SUPABASE_DB_URL"
SUPABASE_DB_URL=postgresql://postgres.your-ref:your-db-password@aws-0-sa-east-1.pooler.supabase.com:5432/postgres
